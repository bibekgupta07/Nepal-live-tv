<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep dark base with a subtle warm glow from the upper-left corner.
         Matches the foreground iris and keeps the launcher icon legible
         regardless of the user's home-screen wallpaper. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:type="linear">
                <item android:offset="0" android:color="#FF1F0A12"/>
                <item android:offset="0.5" android:color="#FF130208"/>
                <item android:offset="1" android:color="#FF080003"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft red radial bloom behind the iris, sits below the foreground -->
    <path android:pathData="M54,54 m-46,0 a46,46 0,1 1,92 0 a46,46 0,1 1,-92 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54" android:centerY="54"
                android:gradientRadius="46"
                android:type="radial">
                <item android:offset="0" android:color="#33E63946"/>
                <item android:offset="1" android:color="#00E63946"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
